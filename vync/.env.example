# Backend Configuration
REACT_APP_SERVER_URL=ws://localhost:8000

# Conference Settings
REACT_APP_DEFAULT_ROOM_ID=room-123
REACT_APP_DEFAULT_USER_ID=user-456

# Camera Settings
REACT_APP_CAMERA_WIDTH=640
REACT_APP_CAMERA_HEIGHT=480
REACT_APP_CAMERA_FPS=30

# Microphone Settings
REACT_APP_AUDIO_SAMPLE_RATE=16000
REACT_APP_AUDIO_CHANNELS=1

# Registration Settings
REACT_APP_SNAPSHOT_COUNT=5
REACT_APP_SNAPSHOT_INTERVAL=500

# Broadcast Settings
REACT_APP_BROADCAST_FPS=15
REACT_APP_ENABLE_VIDEO=true
REACT_APP_ENABLE_AUDIO=true
REACT_APP_ENABLE_FACE_DETECTION=true

# Debug Mode
REACT_APP_DEBUG=false
